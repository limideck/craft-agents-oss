{
  "name": "@grose-agent/server",
  "version": "0.11.1",
  "description": "Standalone headless Grose Agent server (Bun runtime)",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "grose-server": "src/index.ts"
  },
  "files": [
    "src/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": {
    "name": "Grose Docs Ltd.",
    "email": "support@grose.do"
  },
  "license": "Apache-2.0",
  "homepage": "https://agents.grose.do",
  "scripts": {
    "start": "bun run src/index.ts",
    "generate-token": "bun run src/index.ts --generate-token",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grose-agent/core": "workspace:*",
    "@grose-agent/messaging-gateway": "workspace:*",
    "@grose-agent/server-core": "workspace:*",
    "@grose-agent/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0",
    "ws": "^8.16.0"
  }
}
